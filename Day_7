import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.nextLine();

        for(int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            if((ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z')) {

                boolean seen = false;
                for(int k = 0; k < i; k++) {
                    char prev = s.charAt(k);
                    if(prev == ch || prev == ch + 32 || prev == ch - 32) {
                        seen = true;
                        break;
                    }
                }

                if(seen) continue;

                int count = 0;
                for(int j = 0; j < s.length(); j++) {
                    char curr = s.charAt(j);
                    if(curr == ch || curr == ch + 32 || curr == ch - 32) {
                        count++;
                    }
                }

                System.out.println(Character.toLowerCase(ch) + " " + count);
            }
        }
    }
}
